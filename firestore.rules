rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection rules: Users can read and write only their own profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);

      match /withdrawals/{withdrawalId} {
        allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      }
    }

    // Deposits Collection rules: Relational checks against resource data
    match /deposits/{depositId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin()) && isValidDepositRecord(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidDepositRecord(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Withdrawals Collection rules: Secure queries validation
    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin()) && isValidWithdrawalRecord(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidWithdrawalRecord(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Transactions Collection rules: every financial action log
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin()) && isValidTransactionRecord(request.resource.data);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidTransactionRecord(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Dynamic Plans Collection rules
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write, delete: if isAdmin() && isValidPlan(request.resource.data);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "blessingubah38@gmail.com"
      );
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['id', 'name', 'min', 'max', 'roi', 'term'])
             && data.id is string
             && data.id.size() <= 128
             && data.name is string
             && data.name.size() <= 100
             && data.min is number
             && data.max is number
             && data.roi is number
             && data.term is number;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'fullName', 'email'])
             && data.uid is string
             && data.uid.size() <= 128
             && data.username is string 
             && data.username.size() <= 100
             && data.fullName is string 
             && data.fullName.size() <= 100
             && data.email is string 
             && data.email.size() <= 100
             && (!('accountBalance' in data) || data.accountBalance is number)
             && (!('earnedTotal' in data) || data.earnedTotal is number)
             && (!('pendingWithdrawal' in data) || data.pendingWithdrawal is number)
             && (!('totalWithdrew' in data) || data.totalWithdrew is number)
             && (!('activeDeposit' in data) || data.activeDeposit is number)
             && (!('lastDeposit' in data) || data.lastDeposit is number)
             && (!('totalDeposit' in data) || data.totalDeposit is number)
             && (!('lastWithdrawal' in data) || data.lastWithdrawal is string)
             && (!('usdtTrc20' in data) || data.usdtTrc20 is string)
             && (!('bitcoin' in data) || data.bitcoin is string)
             && (!('ethereum' in data) || data.ethereum is string)
             && (!('usdtErc20' in data) || data.usdtErc20 is string);
    }

    function isValidDepositRecord(data) {
      return data.keys().hasAll(['id', 'userId', 'username', 'amount', 'date', 'processor'])
             && data.id is string
             && data.id.size() <= 128
             && data.userId is string
             && data.userId.size() <= 128
             && data.username is string 
             && data.username.size() <= 100
             && data.amount is number
             && data.date is string
             && data.processor is string;
    }

    function isValidWithdrawalRecord(data) {
      return data.keys().hasAll(['id', 'userId', 'username', 'amount', 'date', 'processor'])
             && data.id is string
             && data.id.size() <= 128
             && data.userId is string
             && data.userId.size() <= 128
             && data.username is string 
             && data.username.size() <= 100
             && data.amount is number
             && data.date is string
             && data.processor is string;
    }

    function isValidTransactionRecord(data) {
      return data.keys().hasAll(['id', 'userId', 'username', 'type', 'amount', 'date', 'timestamp', 'status', 'processor'])
             && data.id is string
             && data.id.size() <= 128
             && data.userId is string
             && data.userId.size() <= 128
             && data.username is string 
             && data.username.size() <= 100
             && data.type is string
             && data.amount is number
             && data.date is string
             && data.timestamp is number
             && data.status is string
             && data.processor is string;
    }
  }
}
